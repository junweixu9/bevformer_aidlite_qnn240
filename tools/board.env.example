# Copy this file to tools/board.env and edit it for the target QCS8550 board.
# Host PROJECT_ROOT is intentionally not configured here; scripts derive it
# from their own location so a fresh clone can live anywhere.

BOARD_HOST=aidlux@192.168.111.241
BOARD_PROJECT_ROOT=/home/aidlux/bevformer_aidlite_qnn240

# Frozen QNN2.40 Context paths on the board.
BACKBONE_MODEL_REMOTE=/home/aidlux/bevformer_aidlite_qnn240/models/QCS8550/QNN240/backbone_context.bin
ENCODER_MODEL_REMOTE=/home/aidlux/bevformer_aidlite_qnn240/models/QCS8550/QNN240/encoder_context.bin
DECODER_MODEL_REMOTE=/home/aidlux/bevformer_aidlite_qnn240/models/QCS8550/QNN240/decoder_context.bin

# Ten-frame demonstration manifest: status=PASS and frame_indices=[0..9].
ASSET_MANIFEST_REMOTE=/home/aidlux/bevformer_aidlite_qnn240/assets/unseen10/asset_manifest.json

BACKBONE_SHA=ec709ae41f0dc6b25e2f8950abc8e15a5c85301ac31eea1fa1750927e364c945
